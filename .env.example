# ── AWS Configuration ──────────────────────────────
REGION=ap-south-1

# DynamoDB table used for storing incidents
DYNAMODB_TABLE=incident-escalation-table

# SNS topic used for incident notifications
SNS_TOPIC_NAME=incident-escalation-topic

# ── Cognito Authentication ─────────────────────────
COGNITO_CLIENT_ID=your_cognito_client_id_here
COGNITO_USER_POOL_ID=your_user_pool_id_here

# ── Flask Application ──────────────────────────────
FLASK_SECRET=change_this_secret_key

# ── Escalation Timing Rules (minutes) ──────────────
# JSON format used by the backend
SEVERITY_ESCALATION_MINUTES={"Low":60,"Medium":30,"High":10}